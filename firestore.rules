rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function tripDoc(tripId) {
      return get(/databases/$(database)/documents/trips/$(tripId));
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isTripMember(tripId) {
      return isSignedIn()
        && request.auth.uid in tripDoc(tripId).data.memberIds;
    }

    match /inviteLookups/{token} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['tripId', 'tripName'])
        && request.auth.uid == tripDoc(request.resource.data.tripId).data.createdBy;
      allow update, delete: if false;
    }

    match /trips/{tripId} {
      allow read: if isTripMember(tripId);

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.keys().hasAll([
          'name', 'createdBy', 'inviteToken', 'memberIds', 'createdAt'
        ]);

      allow update: if isTripMember(tripId)
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.inviteToken == resource.data.inviteToken
        && request.resource.data.memberIds == resource.data.memberIds;

      match /members/{userId} {
        allow read: if isTripMember(tripId);
        allow create: if isSignedIn()
          && request.auth.uid == userId
          && request.auth.uid == tripDoc(tripId).data.createdBy;
        allow update, delete: if false;
      }

      match /expenses/{expenseId} {
        allow read: if isTripMember(tripId);
        allow create, update, delete: if isTripMember(tripId);
      }

      match /media/{mediaId} {
        allow read: if isTripMember(tripId);
        allow create, delete: if isTripMember(tripId);
        allow update: if isTripMember(tripId);
      }

      match /timelineEvents/{eventId} {
        allow read: if isTripMember(tripId);
        allow create, update, delete: if isTripMember(tripId);
      }

      match /route/{docId} {
        allow read: if isTripMember(tripId);
        allow create, update, delete: if isTripMember(tripId);
      }

      match /checklistItems/{itemId} {
        allow read: if isTripMember(tripId);
        allow create: if isTripMember(tripId)
          && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if isTripMember(tripId);
      }

      match /checklistReminders/{reminderId} {
        allow read: if isTripMember(tripId);
        allow create: if isTripMember(tripId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.keys().hasAll(['createdBy', 'createdAt']);
      }

      match /memberReminders/{reminderId} {
        allow read: if isTripMember(tripId);
        allow create: if isTripMember(tripId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.keys().hasAll(['createdBy', 'createdAt']);
      }
    }
  }
}
